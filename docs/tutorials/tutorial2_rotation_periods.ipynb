   "source": [
    "# Initialise MovingTPF for asteroid 1980 VR1 in TESS sector 1, camera 1, CCD 1\n",
    "target = MovingTPF.from_name(\"1980 VR1\", sector=1, camera=1, ccd=1)\n",
    "\n",
    "# Make TPF\n",
    "target.make_tpf()\n",
    "\n",
    "# Make aperture photometry LC\n",
    "target.make_lc(method=\"aperture\")\n",
    "lc = target.lc[\"aperture\"]"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b197c76b-a874-414e-a819-8376268821cd",
   "metadata": {},
   "source": [
    "## Clean the data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "da800ed9-f2dd-4aa7-b0d4-248ecfdd9cf2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Before masking = 972\n",
      "After nan masking = 959\n"
     ]
    }
   ],
   "source": [
    "# Remove nans from LC (the periodogram doesn't like nans!)\n",
    "\n",
    "no_nan = np.logical_and(~np.isnan(np.array(lc[\"flux\"])), ~np.isnan(np.array(lc[\"flux_err\"])))\n",
    "time, flux, flux_err = lc[\"time\"][no_nan], lc[\"flux\"][no_nan], lc[\"flux_err\"][no_nan]\n",
    "print(\"Before masking = {0}\".format(len(lc[\"time\"])))\n",
    "print(\"After nan masking = {0}\".format(len(time)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "82f324ae-c141-475f-9ef2-de7946d6e627",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "After bad data masking = 959\n"
     ]
    }
   ],
   "source": [
    "# Remove poor quality data from LC, using built-in helper function with default settings.\n",
    "# This masks cadences with bad SPOC quality and bad lightcurve quality.\n",
    "\n",
    "good_quality = target.create_lc_quality_mask(target.quality[no_nan],lc[\"quality\"][no_nan])\n",
    "time, flux, flux_err = time[good_quality], flux[good_quality], flux_err[good_quality]\n",
    "print(\"After bad data masking = {0}\".format(len(time)))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "608e07ab-7824-45d9-9cd9-d26c8ce24955",
   "metadata": {},
   "source": [
    "## Run a periodogram"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "b0ceb1ea-f192-4f74-8959-9afb3f992367",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Min/max period, in days, and frequency\n",
    "cadence = 30/60/24   # sector 1 had 30min observing cadence\n",
    "Pmin, Pmax = cadence*2, (np.nanmax(time)-np.nanmin(time))\n",
    "fmin, fmax = 1/Pmax, 1/Pmin\n",
    "\n",
    "# Define period and frequency grid\n",
    "frequency_grid = np.linspace(fmin, fmax, 10000)\n",
    "period_grid = 1.0/frequency_grid\n",
    "\n",
    "# Run periodogram\n",
    "ls = LombScargle(time, flux, flux_err)\n",
    "power = ls.power(frequency_grid)\n",
    "\n",
    "# False alarm levels\n",
    "probabilities = [0.1,0.05,0.01]\n",
    "false_alarm_levels = ls.false_alarm_level(probabilities)\n",
    "\n",
    "# Find peaks in the periodogram above 1% FAP.\n",
    "level = false_alarm_levels[2]\n",
    "peaks, peak_properties = find_peaks(power, height=level)\n",
    "peak_periods = period_grid[peaks]\n",
    "sorted_ind = np.argsort(peak_properties[\"peak_heights\"])[::-1]\n",
    "best_period = peak_periods[sorted_ind[0]]*24"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "75ac4948-2ce8-4de1-a1fe-4b3297cd76d5",
   "metadata": {},
